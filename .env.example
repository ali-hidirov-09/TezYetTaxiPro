# ================================================================
# TezYet Taxi — muhit o'zgaruvchilari
# Foydalanish: cp .env.example .env
# ================================================================

# --- Majburiy ---
# Kuchli kalit: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# --- Ilova rejimi ---
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# --- PostgreSQL ---
POSTGRES_DB=tezyettaxi
POSTGRES_USER=tezyetuser
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- CORS (frontend domenlari vergul bilan yoziladi) ---
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# --- Infobip SMS ---
# https://www.infobip.com/ — bepul trial bor, KZ (+7) va UZB (+998) uchun
INFOBIP_API_KEY=
INFOBIP_BASE_URL=xxxxx.api.infobip.com
INFOBIP_SENDER=TezYet
SMS_SKIP_IN_DEV=False

# --- Google Maps ---
# https://console.cloud.google.com -> APIs -> Distance Matrix API
# Bo'sh qoldirilsa haversine formula ishlatiladi (taxminiy masofa)
GOOGLE_MAPS_API_KEY=

# --- Sentry (ixtiyoriy, xatolarni kuzatish) ---
# https://sentry.io/ — bepul
SENTRY_DSN=

# --- Nginx ---
# docker-compose.prod.yml da ishlatiladi
NGINX_SERVER_NAME=yourdomain.com

# --- Gunicorn ---
# (2 × CPU_COUNT) + 1 formulasi tavsiya etiladi
GUNICORN_WORKERS=3


# ================================================================
# Development uchun minimal .env namunasi:
# ================================================================
# SECRET_KEY=django-insecure-dev-only-change-in-production
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
# POSTGRES_DB=tezyettaxi
# POSTGRES_USER=tezyetuser
# POSTGRES_PASSWORD=devpassword
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
# REDIS_URL=redis://redis:6379/0
# SMS_SKIP_IN_DEV=True


